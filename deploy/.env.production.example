# ══════════════════════════════════════════════════════════
# 赛博投研 — 生产环境变量模板
# 复制为 .env.production 并填入实际值
# ⚠️ 请勿将 .env.production 提交到 Git
# ══════════════════════════════════════════════════════════

# ── 应用配置 ──
APP_NAME=赛博投研
APP_ENV=production
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=false
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 数据库 / Redis（复用服务器现有容器） ──
DATABASE_URL=postgresql+asyncpg://<user>:<password>@postgresSQL:5432/<database>

REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/3
CELERY_RESULT_BACKEND=redis://redis:6379/4

# ── CORS（只允许实际域名） ──
CORS_ORIGINS=["https://ai.shuai.help"]
FRONTEND_URL=https://ai.shuai.help

# ── 对象存储 ──
S3_ENDPOINT_URL=http://43.155.204.215:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=cyber-invest
S3_REGION=us-east-1
S3_USE_SSL=false

# ── LLM ──
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# ── Skill LLM Profiles（为空时回退到 OPENAI_*）──
LLM_DATA_BASE_URL=
LLM_DATA_API_KEY=
LLM_DATA_MODEL=
LLM_SYNTHESIS_BASE_URL=
LLM_SYNTHESIS_API_KEY=
LLM_SYNTHESIS_MODEL=

# ── 金十 MCP ──
JIN10_MCP_SERVER_URL=https://mcp.jin10.com/mcp
JIN10_MCP_BEARER_TOKEN=
JIN10_MCP_PROTOCOL_VERSION=2025-11-25
JIN10_MCP_TIMEOUT=20
