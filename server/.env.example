# ══════════════════════════════════════════════════════════
# 赛博投研 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ══════════════════════════════════════════════════════════

# ── 应用基础信息 ──
APP_NAME=赛博投研                          # 应用名称，显示在日志和 API 文档标题中
APP_ENV=local                              # 运行环境：local / remote-dev / staging / production
APP_VERSION=0.1.0                          # 应用版本号，返回在 /health 接口中
API_V1_PREFIX=/api/v1                      # API v1 路由前缀
DEBUG=true                                 # 调试模式：true 开启详细日志，生产环境务必设为 false

# ── 安全与认证 ──
SECRET_KEY=change-me                       # JWT 签名密钥，生产环境必须替换为随机强密钥
ACCESS_TOKEN_EXPIRE_MINUTES=1440           # JWT 令牌过期时间（分钟），1440 = 24 小时

# ── 数据库（PostgreSQL + asyncpg） ──
# 格式：postgresql+asyncpg://<用户名>:<密码>@<主机>:<端口>/<数据库名>
# Alembic 迁移时会自动转换为同步驱动 postgresql://...
DATABASE_URL=postgresql+asyncpg://cyber_invest:cyber_invest@localhost:5432/cyber_invest

# ── Redis ──
REDIS_URL=redis://localhost:6379/2             # 应用缓存和会话，使用 db2
CELERY_BROKER_URL=redis://localhost:6379/3     # Celery 消息队列，使用 db3
CELERY_RESULT_BACKEND=redis://localhost:6379/4 # Celery 任务结果存储，使用 db4

# ── 前端与跨域 ──
FRONTEND_URL=http://localhost:3000                                    # 前端地址，用于邮件链接等场景
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]       # 允许的跨域来源（JSON 数组格式）

# ── 对象存储（S3 / MinIO） ──
S3_ENDPOINT_URL=http://localhost:9000          # S3 兼容存储端点（MinIO 地址）
S3_ACCESS_KEY=minioadmin                        # 存储访问密钥
S3_SECRET_KEY=minioadmin                        # 存储秘密密钥
S3_BUCKET=cyber-invest                          # 默认存储桶名称
S3_REGION=us-east-1                             # 存储区域
S3_USE_SSL=false                                # 是否使用 HTTPS 连接存储

# ── LLM 大模型（OpenAI 兼容接口） ──
OPENAI_BASE_URL=                           # API 地址，如 https://api.openai.com 或 https://api.deepseek.com
OPENAI_API_KEY=                            # API 密钥
OPENAI_MODEL=                              # 默认模型，如 gpt-4o-mini / deepseek-chat / qwen-plus
